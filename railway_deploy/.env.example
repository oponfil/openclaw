# Пример переменных для скрипта railway-create-bot.ts
# Скопируйте в .env и подставьте свои значения: cp .env.example .env

# --- Обязательные ---

# Токен Railway API (Account или Workspace).
# Создать: https://railway.com/account/tokens
RAILWAY_TOKEN=

# ID проекта Railway. В дашборде: Cmd/Ctrl+K → Copy Project ID
RAILWAY_PROJECT_ID=

# --- Опциональные ---

# Токен бота Telegram от @BotFather (если не задан — инстанс без Telegram, можно добавить позже в Railway)
# TELEGRAM_BOT_TOKEN=

# ID окружения (если не задан — берётся первое в проекте). Cmd/Ctrl+K → Copy Environment ID
# RAILWAY_ENVIRONMENT_ID=

# Токен gateway для нового инстанса (если не задан — генерируется скриптом)
# OPENCLAW_GATEWAY_TOKEN=

# Пароль для /setup на новом инстансе (можно задать и флагом --setup-password)
# SETUP_PASSWORD=

# GitHub-репозиторий для source=github (owner/repo или полный URL). По умолчанию oponfil/openclaw
# RAILWAY_GITHUB_REPO=https://github.com/oponfil/openclaw
